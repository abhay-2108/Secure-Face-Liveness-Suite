react-native-open-face/aegis-app/android/app/build/
**/local.properties
*.keystore
!debug.keystore

# iOS
react-native-open-face/ios/build/
react-native-open-face/aegis-app/ios/build/
react-native-open-face/aegis-app/ios/Pods/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

