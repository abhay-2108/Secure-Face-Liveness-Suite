{
  "name": "react-native-datalake-vision",
  "version": "0.1.0",
  "description": "Edge AI facial recognition and liveness detection for React Native — powered by the Datalake 3.0 Rust engine",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-datalake-vision.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "prepare": "bob build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "build": "bob build",
    "example": "cd example && npx react-native run-android"
  },
  "keywords": [
    "react-native",
    "face-recognition",
    "liveness-detection",
    "edge-ai",
    "datalake",
    "nhai",
    "biometric",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/datalake-vision/react-native-datalake-vision"
  },
  "author": "Datalake 3.0 <team@datalake.ai>",
  "license": "MIT",
  "homepage": "https://github.com/datalake-vision/react-native-datalake-vision#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-vision-camera": "^4.0.0",
    "react-native-builder-bob": "^0.23.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-vision-camera": ">=4.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
